<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Promotional Items | Cougar Clothing</title>
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/products.css">
  <link rel="stylesheet" href="/css/cart.css">
  <link rel="icon" type="image/png"
    href="https://cdn.shopify.com/oxygen-v2/48131/89657/185047/3004679/assets/Cougar_Favicon-C0bggmnh.png">
  <!-- Include jQuery for Client-Side Pagination -->
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <style>
    .pagination-controls {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 15px;
      margin-top: 40px;
      margin-bottom: 40px;
    }
    .pagination-controls button {
      padding: 10px 20px;
      background-color: #000;
      color: #fff;
      border: none;
      cursor: pointer;
      font-weight: bold;
    }
    .pagination-controls button:disabled {
      background-color: #ccc;
      cursor: not-allowed;
    }
    .pagination-controls span {
      font-weight: bold;
      font-size: 16px;
    }
  </style>
</head>

<body>

  <!-- ========== ANNOUNCEMENT BAR ========== -->
  <div class="announcement-bar">
    <p>🔥 Up to 50% OFF — Limited Time Sale! | Use Code: <strong>COUGAR10</strong></p>
  </div>

  <!-- ========== SIDEBAR DRAWER ========== -->
  <div class="sidebar-overlay" id="sidebar-overlay"></div>
  <div class="sidebar" id="sidebar">
    <button class="sidebar-close" id="sidebar-close">&times;</button>
    <nav class="sidebar-nav">
      <a href="/onsale-products" class="sale-link">Promo Sale</a>
      <a href="/sale">Sale</a>
      <a href="/men">Men</a>
      <a href="/women">Women</a>
      <a href="/kids">Kids</a>
    </nav>
  </div>

  <!-- ========== HEADER ========== -->
  <header class="header">
    <div class="header-inner">
      <button class="hamburger" id="hamburger" title="Menu">&#9776;</button>

      <nav class="nav-links" id="nav-links">
        <a href="/onsale-products" class="sale-link">Promo Sale</a>
        <a href="/sale">Sale</a>
        <a href="/men">Men</a>
        <a href="/women">Women</a>
        <a href="/kids">Kids</a>
      </nav>

      <div class="logo-center">
        <a href="/">
          <img src="https://cdn.shopify.com/oxygen-v2/48131/89657/185047/3004679/assets/Group-BhvqCM7d.svg"
            alt="Cougar Clothing Logo">
        </a>
      </div>

      <nav class="header-icons">
        <button class="icon-btn" title="Search">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
            stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
        </button>
        <a href="/cart" title="Cart" class="cart-icon-link">
          <img src="https://cdn.shopify.com/oxygen-v2/48131/89657/185047/3004679/assets/Cart-CnL1VNMu.svg" alt="Cart"
            class="icon">
          <% if (cartCount > 0) { %>
            <span class="cart-badge"><%= cartCount %></span>
          <% } %>
        </a>
        <!-- User Auth -->
        <div class="user-menu" style="display:inline-block; margin-left:10px; font-size:14px;">
          <% if (user) { %>
            <a href="/logout" title="Logout" style="color:#d9534f; text-decoration:none; font-weight:bold;">Logout</a> / 
            <span style="font-weight:bold; color:#333;"><%= user.name %></span>
            <% if (user.role === 'admin') { %>
              <a href="/admin" title="Admin" style="margin-left:5px; color:#5bc0de; text-decoration:none; font-weight:bold;">(Admin)</a>
            <% } %>
            <a href="/orders" style="margin-left:8px; color:#374151; text-decoration:none; font-weight:bold;">My Orders</a>
          <% } else { %>
            <a href="/login" style="color:#000; text-decoration:none; font-weight:bold;">Login / Register</a>
          <% } %>
        </div>
      </nav>
    </div>
  </header>

  <%- include('partials/flash-messages') %>

  <!-- ========== MAIN ========== -->
  <main class="products-page">

    <!-- Category Hero -->
    <div class="cat-hero cat-hero--sale">
      <div class="cat-hero-content">
        <span class="cat-hero-label">Promotional</span>
        <h1>On-Sale Items</h1>
      </div>
    </div>

    <!-- Product Grid -->
    <div class="container" style="padding: 40px 20px;">
      <div class="row" id="product-list" style="display: flex; flex-wrap: wrap; gap: 20px; justify-content: center;">
        <% if (products.length === 0) { %>
          <p>No promotional items available right now.</p>
        <% } else { %>
          <% products.forEach(function(product) { %>
            <div class="onsale-item" style="width: 250px; border: 1px solid #eee; padding: 10px; border-radius: 8px; text-align: center;">
              <a href="#">
                <img src="<%= product.image %>" alt="<%= product.name %>" style="width: 100%; height: 250px; object-fit: cover; border-radius: 4px;">
              </a>
              <h3 style="font-size: 16px; margin: 15px 0 5px;"><%= product.name %></h3>
              <p style="color: #d9534f; font-weight: bold;">Rs. <%= product.price %></p>
              
              <form action="/cart/add" method="POST" style="margin-top: 15px;">
                <input type="hidden" name="productId" value="<%= product._id %>">
                <button type="submit" style="width: 100%; padding: 10px; background: #000; color: #fff; border: none; cursor: pointer;">Add to Cart</button>
              </form>
            </div>
          <% }); %>
        <% } %>
      </div>

      <!-- Pagination Controls -->
      <% if (products.length > 0) { %>
        <div class="pagination-controls">
          <button id="prev-btn">Previous</button>
          <span id="page-indicator">Page 1</span>
          <button id="next-btn">Next</button>
        </div>
      <% } %>
    </div>

  </main>

  <!-- ========== FOOTER ========== -->
  <footer class="footer">
    <div class="container">
      <div class="footer-bottom">
        <p>&copy; Copyrights Reserved by <a href="#">Cougar Clothing</a> 2026.</p>
      </div>
    </div>
  </footer>

  <script src="/js/script.js"></script>

  <!-- ========== CLIENT-SIDE PAGINATION (JQUERY) ========== -->
  <script>
    $(document).ready(function() {
      const $items = $('.onsale-item');
      const totalItems = $items.length;
      const itemsPerPage = 10;
      let currentPage = 1;
      const totalPages = Math.ceil(totalItems / itemsPerPage) || 1;

      // Function to show items for the current page
      function showPage(page) {
        // Hide all items first
        $items.hide();
        
        // Calculate the slice range
        const startIndex = (page - 1) * itemsPerPage;
        const endIndex = startIndex + itemsPerPage;
        
        // Use jQuery .slice() to filter to the exact 10 items, and show them
        $items.slice(startIndex, endIndex).show();
        
        // Update Indicator
        $('#page-indicator').text(`Page ${page} of ${totalPages}`);
        
        // Handle Prev Button state
        if (page <= 1) {
          $('#prev-btn').prop('disabled', true);
        } else {
          $('#prev-btn').prop('disabled', false);
        }
        
        // Handle Next Button state
        if (page >= totalPages) {
          $('#next-btn').prop('disabled', true);
        } else {
          $('#next-btn').prop('disabled', false);
        }
      }

      // Initialize the first page
      if(totalItems > 0) {
        showPage(currentPage);
      }

      // Next Button Click
      $('#next-btn').click(function() {
        if (currentPage < totalPages) {
          currentPage++;
          showPage(currentPage);
          // Optional: scroll back to top of product list
          $('html, body').animate({ scrollTop: $('#product-list').offset().top - 100 }, 200);
        }
      });

      // Previous Button Click
      $('#prev-btn').click(function() {
        if (currentPage > 1) {
          currentPage--;
          showPage(currentPage);
          // Optional: scroll back to top of product list
          $('html, body').animate({ scrollTop: $('#product-list').offset().top - 100 }, 200);
        }
      });
    });
  </script>

</body>
</html>

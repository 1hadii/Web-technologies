<% if (success_msg && success_msg.length > 0) { %>
  <div class="alert alert-success" style="padding:15px; margin: 10px auto; max-width:800px; background-color: #d4edda; color:#155724; border: 1px solid #c3e6cb; border-radius:4px; text-align:center;">
    <%= success_msg %>
  </div>
<% } %>

<% if (error_msg && error_msg.length > 0) { %>
  <div class="alert alert-danger" style="padding:15px; margin: 10px auto; max-width:800px; background-color: #f8d7da; color:#721c24; border: 1px solid #f5c6cb; border-radius:4px; text-align:center;">
    <%= error_msg %>
  </div>
<% } %>

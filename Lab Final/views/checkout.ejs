<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Checkout | Cougar Clothing</title>
  <meta name="description" content="Complete your order at Cougar Clothing. Enter your shipping details and confirm your purchase.">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/cart.css">
  <link rel="icon" type="image/png"
    href="https://cdn.shopify.com/oxygen-v2/48131/89657/185047/3004679/assets/Cougar_Favicon-C0bggmnh.png">
</head>

<body>

  <!-- ========== ANNOUNCEMENT BAR ========== -->
  <div class="announcement-bar">
    <p>Free Shipping on Orders Over Rs. 3,000 | Use Code: <strong>COUGAR10</strong></p>
  </div>

  <!-- ========== SIDEBAR DRAWER ========== -->
  <div class="sidebar-overlay" id="sidebar-overlay"></div>
  <div class="sidebar" id="sidebar">
    <button class="sidebar-close" id="sidebar-close">&times;</button>
    <nav class="sidebar-nav">
      <a href="/onsale-products" class="sale-link" style="color: #ff4757; font-weight: bold; margin-right: 15px;">Promo Sale</a>
        <a href="/sale" class="sale-link">Sale</a>
      <a href="/men">Men</a>
      <a href="/women">Women</a>
      <a href="/kids">Kids</a>
    </nav>
  </div>

  <!-- ========== HEADER ========== -->
  <header class="header">
    <div class="header-inner">
      <button class="hamburger" id="hamburger" title="Menu">&#9776;</button>
      <nav class="nav-links" id="nav-links">
        <a href="/onsale-products" class="sale-link" style="color: #ff4757; font-weight: bold; margin-right: 15px;">Promo Sale</a>
        <a href="/sale" class="sale-link">Sale</a>
        <a href="/men">Men</a>
        <a href="/women">Women</a>
        <a href="/kids">Kids</a>
      </nav>
      <div class="logo-center">
        <a href="/">
          <img src="https://cdn.shopify.com/oxygen-v2/48131/89657/185047/3004679/assets/Group-BhvqCM7d.svg"
            alt="Cougar Clothing Logo">
        </a>
      </div>
      <nav class="header-icons">
        <a href="/cart" title="Cart" class="cart-icon-link">
          <img src="https://cdn.shopify.com/oxygen-v2/48131/89657/185047/3004679/assets/Cart-CnL1VNMu.svg" alt="Cart"
            class="icon">
          <% if (cartCount > 0) { %>
            <span class="cart-badge"><%= cartCount %></span>
          <% } %>
        </a>
        <div class="user-menu" style="display:inline-block; margin-left:10px; font-size:14px;">
          <% if (user) { %>
            <a href="/logout" style="color:#d9534f; text-decoration:none; font-weight:bold;">Logout</a> /
            <span style="font-weight:bold; color:#333;"><%= user.name %></span>
          <% } else { %>
            <a href="/login" style="color:#000; text-decoration:none; font-weight:bold;">Login / Register</a>
          <% } %>
        </div>
      </nav>
    </div>
  </header>

  <%- include('partials/flash-messages') %>

  <!-- ========== MAIN ========== -->
  <main class="checkout-page">

    <!-- Breadcrumb -->
    <nav class="checkout-breadcrumb" aria-label="Checkout steps">
      <span class="crumb crumb--done">Cart</span>
      <span class="crumb-sep">›</span>
      <span class="crumb crumb--active">Shipping</span>
      <span class="crumb-sep">›</span>
      <span class="crumb">Confirmation</span>
    </nav>

    <h1 class="checkout-title">Checkout</h1>

    <div class="checkout-layout">

      <!-- ── Shipping Form ── -->
      <section class="checkout-form-section">
        <h2>Shipping Information</h2>

        <form action="/checkout" method="POST" id="checkout-form" novalidate>

          <!-- Contact -->
          <div class="form-group">
            <label for="fullName">Full Name <span class="req">*</span></label>
            <input type="text" id="fullName" name="fullName"
              value="<%= user ? user.name : '' %>"
              placeholder="Muhammad Ali" required autocomplete="name">
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="email">Email Address <span class="req">*</span></label>
              <input type="email" id="email" name="email"
                value="<%= user ? user.email : '' %>"
                placeholder="ali@example.com" required autocomplete="email">
            </div>
            <div class="form-group">
              <label for="phone">Phone Number <span class="req">*</span></label>
              <input type="tel" id="phone" name="phone"
                placeholder="0300-1234567" required autocomplete="tel">
            </div>
          </div>

          <!-- Address -->
          <div class="form-group">
            <label for="address">Street Address <span class="req">*</span></label>
            <input type="text" id="address" name="address"
              placeholder="House 12, Street 5, Block A" required autocomplete="street-address">
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="city">City <span class="req">*</span></label>
              <input type="text" id="city" name="city"
                placeholder="Lahore" required autocomplete="address-level2">
            </div>
            <div class="form-group">
              <label for="postalCode">Postal Code</label>
              <input type="text" id="postalCode" name="postalCode"
                placeholder="54000" autocomplete="postal-code">
            </div>
          </div>

          <div class="form-group">
            <label for="province">Province <span class="req">*</span></label>
            <select id="province" name="province" required>
              <option value="">Select Province</option>
              <option value="Punjab">Punjab</option>
              <option value="Sindh">Sindh</option>
              <option value="KPK">Khyber Pakhtunkhwa</option>
              <option value="Balochistan">Balochistan</option>
              <option value="Islamabad">Islamabad (ICT)</option>
              <option value="AJK">Azad Jammu & Kashmir</option>
              <option value="Gilgit-Baltistan">Gilgit-Baltistan</option>
            </select>
          </div>

          <!-- Order Notes -->
          <div class="form-group">
            <label for="notes">Order Notes <span class="optional">(optional)</span></label>
            <textarea id="notes" name="notes" rows="3"
              placeholder="Special instructions for your order, e.g. leave at the gate."></textarea>
          </div>

          <!-- Payment Method (informational — COD only) -->
          <div class="payment-section">
            <h3>Payment Method</h3>
            <label class="payment-option payment-option--active">
              <input type="radio" name="paymentMethod" value="cod" checked>
              <span class="payment-icon">💵</span>
              <div>
                <strong>Cash on Delivery</strong>
                <small>Pay when your order arrives</small>
              </div>
              <span class="payment-check">✓</span>
            </label>
          </div>

          <button type="submit" class="btn-place-order" id="place-order-btn">
            <span class="btn-text">Place Order</span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd"
                d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z"
                clip-rule="evenodd" />
            </svg>
          </button>

          <p class="checkout-secure-note">🔒 Your information is secure and encrypted</p>
        </form>
      </section>

      <!-- ── Order Summary ── -->
      <aside class="checkout-summary">
        <h2>Order Summary</h2>

        <div class="checkout-items">
          <% cartItems.forEach(function(item) { %>
            <div class="checkout-item">
              <div class="checkout-item-img">
                <% if (item.image) { %>
                  <img src="<%= item.image %>" alt="<%= item.name %>">
                <% } else { %>
                  <div class="checkout-img-placeholder"></div>
                <% } %>
                <span class="checkout-item-qty"><%= item.quantity %></span>
              </div>
              <div class="checkout-item-info">
                <p class="checkout-item-name"><%= item.name %></p>
                <p class="checkout-item-price">Rs. <%= item.price.toLocaleString() %></p>
              </div>
              <p class="checkout-item-total">Rs. <%= (item.price * item.quantity).toLocaleString() %></p>
            </div>
          <% }); %>
        </div>

        <div class="checkout-summary-lines">
          <div class="summary-line">
            <span>Subtotal</span>
            <span>Rs. <%= cartTotal.toLocaleString() %></span>
          </div>
          <div class="summary-line">
            <span>Shipping</span>
            <span class="<%= cartTotal >= 3000 ? 'free-shipping' : '' %>">
              <%= cartTotal >= 3000 ? 'FREE' : 'Rs. 250' %>
            </span>
          </div>
          <div class="summary-line summary-line--total">
            <span>Total</span>
            <span>Rs. <%= (cartTotal + (cartTotal >= 3000 ? 0 : 250)).toLocaleString() %></span>
          </div>
        </div>

        <a href="/cart" class="btn-edit-cart">← Edit Cart</a>
      </aside>

    </div>
  </main>

  <!-- ========== FOOTER ========== -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>Customer Support</h4>
          <ul>
            <li><a href="mailto:info@cougar.com.pk">info@cougar.com.pk</a></li>
            <li><a href="tel:042-32301484">042-32301484</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Policies</h4>
          <ul>
            <li><a href="#">Return & Exchange Policy</a></li>
            <li><a href="#">Privacy Policy</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; Copyrights Reserved by <a href="#">Cougar Clothing</a> 2026.</p>
      </div>
    </div>
  </footer>

  <script src="/js/script.js"></script>
  <script>
    // Prevent double-submission
    document.getElementById('checkout-form').addEventListener('submit', function () {
      const btn = document.getElementById('place-order-btn');
      btn.disabled = true;
      btn.querySelector('.btn-text').textContent = 'Placing Order…';
    });
  </script>
</body>

</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof product !== 'undefined' ? 'Edit Product' : 'Add New Product' %> | Admin</title>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>

  <!-- Sidebar -->
  <aside class="admin-sidebar">
    <div class="admin-sidebar-header">
      <h2>Cougar Admin</h2>
    </div>
    <nav class="admin-sidebar-nav">
      <a href="/admin">Dashboard</a>
      <a href="/admin/product/new" class="<%= typeof product === 'undefined' ? 'active' : '' %>">Add Product</a>
      <a href="/" target="_blank">View Store</a>
    </nav>
  </aside>

  <!-- Main Content -->
  <main class="admin-main">
    <header class="admin-header">
      <h1><%= typeof product !== 'undefined' ? 'Edit Product' : 'Add New Product' %></h1>
      <a href="/admin" class="btn-primary" style="background-color: #7f8c8d;">&larr; Back to Dashboard</a>
    </header>

    <div class="admin-form-container">
      <form action="<%= typeof product !== 'undefined' ? '/admin/product/edit/' + product._id : '/admin/product/new' %>" method="POST" enctype="multipart/form-data">
        
        <div class="form-group">
          <label for="name">Product Name *</label>
          <input type="text" id="name" name="name" class="form-control" value="<%= typeof product !== 'undefined' ? product.name : '' %>" required>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="price">Price (Rs.) *</label>
            <input type="number" id="price" name="price" class="form-control" min="0" value="<%= typeof product !== 'undefined' ? product.price : '' %>" required>
          </div>
          <div class="form-group">
            <label for="stock">Stock Quantity *</label>
            <input type="number" id="stock" name="stock" class="form-control" min="0" value="<%= typeof product !== 'undefined' ? product.stock : '' %>" required>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="category">Category *</label>
            <select id="category" name="category" class="form-control" required>
              <option value="">Select Category</option>
              <% const categories = ["Men", "Women", "Kids", "Accessories", "Sale"]; %>
              <% categories.forEach(cat => { %>
                <option value="<%= cat %>" <%= typeof product !== 'undefined' && product.category === cat ? 'selected' : '' %>><%= cat %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label for="subCategory">Sub-Category</label>
            <select id="subCategory" name="subCategory" class="form-control">
              <% const subCats = ["Jackets", "T-Shirts", "Pants", "Other"]; %>
              <% subCats.forEach(sub => { %>
                <option value="<%= sub %>" <%= typeof product !== 'undefined' && product.subCategory === sub ? 'selected' : (typeof product === 'undefined' && sub === 'Other' ? 'selected' : '') %>><%= sub %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label for="rating">Rating (1-5) *</label>
          <input type="number" id="rating" name="rating" class="form-control" min="1" max="5" step="0.1" value="<%= typeof product !== 'undefined' ? product.rating : '5' %>" required>
        </div>

        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description" class="form-control" rows="4"><%= typeof product !== 'undefined' ? product.description : '' %></textarea>
        </div>

        <div class="form-group">
          <label for="image">Product Image Upload</label>
          <input type="file" id="image" name="image" class="form-control" accept="image/*" <%= typeof product === 'undefined' ? '' : '' %>>
          <% if (typeof product !== 'undefined' && product.image) { %>
            <p style="margin-top: 10px; font-size: 0.9rem; color: #7f8c8d;">Current Image:</p>
            <img src="<%= product.image %>" alt="Current Image" class="current-image-preview">
          <% } %>
        </div>

        <button type="submit" class="btn-primary" style="width: 100%; margin-top: 10px; padding: 15px;">
          <%= typeof product !== 'undefined' ? 'Update Product' : 'Create Product' %>
        </button>

      </form>
    </div>
  </main>

</body>
</html>
